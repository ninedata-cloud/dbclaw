# NineData DBGuard Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=NineData DBGuard
APP_HOST=0.0.0.0
APP_PORT=9939
DEBUG=true

# Encryption key for database passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Authentication / session secrets
PUBLIC_SHARE_SECRET_KEY=replace-with-random-public-share-secret
# Required only when bootstrapping the very first admin user
INITIAL_ADMIN_PASSWORD=replace-with-initial-admin-password

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Database (PostgreSQL)
# When running via Docker (single container), this is set automatically.
# For local development, set to your PostgreSQL connection string:
DATABASE_URL=postgresql+asyncpg://dbguard:DbGuard2026@localhost:5432/dbguard
POSTGRES_DB=dbguard
POSTGRES_USER=dbguard
POSTGRES_PASSWORD=DbGuard2026

# Metric collection interval (seconds)
METRIC_INTERVAL=15

# Knowledge Base Configuration
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
KNOWLEDGE_BASE_DIR=./data/knowledge_bases

# Bocha AI Web Search API
BOCHA_API_KEY=your-bocha-api-key-here
BOCHA_API_URL=https://api.bochaai.com/v1/web-search
