# DBClaw Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=DBClaw
# 留空时使用代码内置版本；发布构建可通过 Docker build --build-arg 注入
APP_VERSION=
BUILD_COMMIT=
BUILD_TIME=
APP_HOST=0.0.0.0
APP_PORT=9939
DEBUG=true
LOG_LEVEL=DEBUG
# text 或 json；Docker 场景推荐 json，方便日志平台采集
LOG_FORMAT=text
ACCESS_LOG_ENABLED=true
LOG_FILE_ENABLED=true
# 本地开发默认可用 data/logs；Docker 单容器部署建议使用 /app/data/logs
LOG_DIR=data/logs
LOG_FILE_MAX_BYTES=104857600
LOG_FILE_BACKUP_COUNT=10
# SQL Server 连接使用的 ODBC 驱动名；Docker 镜像默认安装 ODBC Driver 18 for SQL Server
SQLSERVER_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Encryption key for database passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# Docker 单容器部署时可留空，首次启动会自动生成并持久化到 /app/data/bootstrap/runtime.env
ENCRYPTION_KEY=your-fernet-key-here

# Authentication / session secrets
# Docker 单容器部署时可留空，首次启动会自动生成并持久化
PUBLIC_SHARE_SECRET_KEY=replace-with-random-public-share-secret
# 默认管理员密码为 admin1234，可通过环境变量覆盖
INITIAL_ADMIN_PASSWORD=admin1234

# Database (PostgreSQL)
# When running via Docker (single container), these values are optional and will be auto-generated if omitted.
# For local development, set to your PostgreSQL connection string:
DATABASE_URL=postgresql+asyncpg://dbclaw:your-postgres-password@localhost:5432/dbclaw
POSTGRES_DB=dbclaw
POSTGRES_USER=dbclaw
POSTGRES_PASSWORD=

# Metric collection interval (seconds)
METRIC_INTERVAL=15
